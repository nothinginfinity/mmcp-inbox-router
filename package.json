{
  "name": "@nothinginfinity/mmcp-inbox-router",
  "version": "0.1.0",
  "description": "GitHub-native MMCP inbox router — deterministic envelope classification and action dispatch",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mmcp-router": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "format": "biome format --write src/"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": ["mmcp", "agent", "inbox", "router", "pocket-agent-engine"],
  "license": "MIT"
}
